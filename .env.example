# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: (Optional) The hosted API backend URL. Prepend during native client builds (e.g. Capacitor Android/iOS builds).
VITE_API_BASE_URL="https://space-station-commander.onrender.com"

# PostgreSQL Database Connections (Cloud SQL Setup)
SQL_HOST="localhost"
SQL_USER="postgres"
SQL_PASSWORD="password"
SQL_DB_NAME="database"

# Cloud Redis Connection (Permanently configured in antiCheat.ts)
REDIS_HOST="note-believe-rosegold-84519.db.redis.io"
REDIS_PORT=14372
REDIS_PASSWORD="i73aF6P0isDnIWJTBq4X9Rw1oANUV9Ie"

# Migration Admin credentials (Optional, defaults to SQL_USER if same)
SQL_ADMIN_USER="ai_studio_admin"
SQL_ADMIN_PASSWORD="admin_password"

# Firebase Native Push Notifications (FCM Fallback) configuration
# Paste your full Firebase Service Account JSON string here (e.g. {"type": "service_account", ...})
FIREBASE_SERVICE_ACCOUNT=
# Or provide your Firebase Project ID for fallback/local development logging
FIREBASE_PROJECT_ID=
